# =============================================================================
# Gemini Sales Accelerator Core — Environment Variables
#
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# ── Database ──
DATABASE_URL=postgresql+asyncpg://gsa_user:gsa_local_password@localhost:5432/gsa_core
DATABASE_URL_SYNC=postgresql://gsa_user:gsa_local_password@localhost:5432/gsa_core

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Application ──
APP_ENV=development
API_KEY=gsa_dev_key_change_me_in_production
LOG_LEVEL=DEBUG

# ── Google Cloud (Phase 2) ──
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# BRIEFING_AGENT_ENGINE_ID=
# CHAT_AGENT_ENGINE_ID=
