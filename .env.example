# =============================================================================
# Gemini Sales Accelerator Core — Environment Variables
#
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
#
# docker-compose.yml reads from this root-level .env file automatically.
# =============================================================================

# ── Database ──
# Docker Compose uses container hostnames (postgres, redis).
# For local non-Docker development, change to localhost.
DATABASE_URL=postgresql+asyncpg://gsa_user:gsa_local_password@postgres:5432/gsa_core
DATABASE_URL_SYNC=postgresql://gsa_user:gsa_local_password@postgres:5432/gsa_core

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Application ──
APP_ENV=development
API_KEY=gsa_dev_key_change_me_in_production
LOG_LEVEL=DEBUG

# ── Google Cloud ──
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL_NAME=gemini-2.5-flash

# Auth: Uses Application Default Credentials (ADC) automatically.
# Local: run `gcloud auth application-default login`
# Cloud Run: uses the attached service account

# ── Vertex AI Agents ──
# Set these after deploying agents via examples/vertex-agents/*/deploy.py
# BRIEFING_AGENT_ENGINE_ID=5864266157464223744
# CHAT_AGENT_ENGINE_ID=

# ── ngrok Tunnel (optional) ──
# Set your auth token to auto-start an ngrok tunnel on `./scripts/setup-local.sh`
# Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here
#
# Optional: claim a free static domain at https://dashboard.ngrok.com/domains
# This gives you a stable URL so frontends (Google Sheets, etc.) don't need updating.
# NGROK_DOMAIN=your-name.ngrok-free.app
